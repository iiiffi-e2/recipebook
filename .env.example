# Supabase — Project Settings → API Keys
# Project URL (must start with https://, e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Browser-safe key only: publishable (sb_publishable_...) or legacy anon (eyJ...).
# Never put sb_secret_... or service_role here — Supabase blocks secret keys in the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key-here

# Server-only admin key (optional). Prefer legacy service_role JWT, or keep secret keys
# out of NEXT_PUBLIC_* vars. Never expose this to the client.
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-or-secret-key-here

# OpenAI — optional; recipe import, assistant, and hero images use fallbacks without it
OPENAI_API_KEY=sk-your-openai-key-here
