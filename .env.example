# Supabase — Project Settings → API
# Project URL (must start with https://, e.g. https://abcdefgh.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# anon public key only — never use service_role here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# OpenAI — optional; recipe import, assistant, and hero images use fallbacks without it
OPENAI_API_KEY=sk-your-openai-key-here
